
# Keybinds
keybind = shift+enter=text:\n
# Split navigation (super + jk)
keybind = super+j=goto_split:up
keybind = super+k=goto_split:down

# Visual: font, theme, cursors
#font-family = "JetBrains Mono"
font-size = 16

background-opacity = 0.9
background-blur-radius = 20

# Try `xcodedarkhc` for higher contrast
theme = Aura
cursor-style = underline

quick-terminal-position = top
quick-terminal-autohide = true

initial-window = false

# Shell and OS integration
term=xterm-256color
shell-integration = zsh
shell-integration-features = cursor, sudo, title

# Decoration was broken on MacOS 26
# macos-titlebar-style = hidden
# window-decoration = false

# Tab titlebar style - try different values for better tab visibility
# Valid options: native, transparent, tabs, hidden
macos-titlebar-style = tabs
window-theme = system
macos-option-as-alt = true

# YOLO updates
auto-update-channel = tip


# Don't show a dialog when I'm slamming cmd+q
#confirm-close-surface = false

# Auto-update settings
auto-update = download

# Quick Terminal
quick-terminal-animation-duration = 0
